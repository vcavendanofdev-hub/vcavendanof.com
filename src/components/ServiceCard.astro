---
import type { ServiceSummary } from '../content/site/types';

interface Props {
  service: ServiceSummary;
}

const { service } = Astro.props;
---

<article class="service-card card">
  <p class="eyebrow">{service.descriptor}</p>
  <h3>{service.title}</h3>
  <ul>
    {service.points.map((point) => <li>{point}</li>)}
  </ul>
  <a class="btn btn--secondary" href={service.href}>{service.cta}</a>
</article>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-card ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-slate);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-grow: 1;
  }

  .service-card .btn {
    align-self: flex-start;
    margin-top: 0.5rem;
  }
</style>
