---
import type { ExperienceItem } from '../content/site/types';

interface Props {
  items: ExperienceItem[];
}

const { items } = Astro.props;
---

<div class="experience-list">
  {items.map((item) => (
    <div class="experience-item">
      <div class="experience-item__meta">
        <h3>{item.org}</h3>
        <p class="experience-item__role">{item.role}</p>
        <p class="experience-item__period">{item.period}</p>
      </div>
      <p class="experience-item__benefit">{item.benefit}</p>
    </div>
  ))}
</div>

<style>
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .experience-item {
    display: grid;
    grid-template-columns: minmax(180px, 240px) 1fr;
    gap: 1.5rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--color-line);
  }

  .experience-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .experience-item__meta h3 {
    margin-bottom: 0.15rem;
    font-size: 1.1rem;
  }

  .experience-item__role {
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 0.15rem;
  }

  .experience-item__period {
    font-size: 0.88rem;
    color: var(--color-slate);
    margin-bottom: 0;
  }

  .experience-item__benefit {
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .experience-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
