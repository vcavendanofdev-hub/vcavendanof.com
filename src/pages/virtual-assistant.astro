---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServicePageBody from '../components/ServicePageBody.astro';
import { getSite } from '../content/site';

const locale = 'en' as const;
const { va } = getSite(locale);
---

<BaseLayout
  locale={locale}
  title={va.meta.title}
  description={va.meta.description}
  path="/virtual-assistant"
  altPath="/es/virtual-assistant"
>
  <ServicePageBody content={va} contactHref="/contact" />
</BaseLayout>
