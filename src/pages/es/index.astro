---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import StatGrid from '../../components/StatGrid.astro';
import { getSite } from '../../content/site';

const locale = 'es' as const;
const { hub } = getSite(locale);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Victor Avendaño',
  description: hub.meta.description,
  founder: {
    '@type': 'Person',
    name: 'Victor Camilo Avendaño Forero',
    email: 'mailto:melethestel@gmail.com',
    sameAs: ['https://linkedin.com/in/vavendanof'],
  },
  areaServed: 'Worldwide',
  availableLanguage: ['es', 'en'],
};
---

<BaseLayout
  locale={locale}
  title={hub.meta.title}
  description={hub.meta.description}
  path="/es"
  altPath="/"
  structuredData={structuredData}
>
  <section class="section hero">
    <div class="container hero__inner">
      <p class="eyebrow">{hub.hero.descriptor}</p>
      <h1 class="tagline">{hub.hero.tagline}</h1>
      <p class="hero__intro">{hub.hero.intro}</p>
      <div class="hero__ctas">
        <a class="btn btn--primary" href="/es/project-manager">{hub.hero.ctaPM}</a>
        <a class="btn btn--secondary" href="/es/virtual-assistant">{hub.hero.ctaVA}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container about">
      <p class="eyebrow">{hub.about.eyebrow}</p>
      <h2>{hub.about.heading}</h2>
      <div class="about__body">
        {hub.about.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="section section--tight achievements">
    <div class="container">
      <h2>{hub.achievements.heading}</h2>
      <StatGrid stats={hub.achievements.stats} />
    </div>
  </section>

  <section class="section compare">
    <div class="container">
      <p class="eyebrow">{hub.compare.eyebrow}</p>
      <h2>{hub.compare.heading}</h2>
      <p class="compare__intro">{hub.compare.intro}</p>
      <div class="grid grid--2">
        <ServiceCard service={hub.compare.pm} />
        <ServiceCard service={hub.compare.va} />
      </div>
    </div>
  </section>

  <section class="section section--tight contact-cta">
    <div class="container contact-cta__inner">
      <div>
        <h2>{hub.contactCta.heading}</h2>
        <p>{hub.contactCta.body}</p>
      </div>
      <a class="btn btn--primary" href="/es/contact">{hub.contactCta.cta}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero__inner {
    max-width: 780px;
  }

  .hero h1 {
    font-size: clamp(1.7rem, 3vw + 1rem, 2.4rem);
    margin-bottom: 0.9rem;
  }

  .hero__intro {
    font-size: 1.1rem;
    max-width: 640px;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .about__body {
    max-width: 780px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .compare__intro {
    max-width: 680px;
    margin-bottom: 2rem;
  }

  .achievements {
    background: var(--color-ink);
    border-radius: var(--radius-lg);
    margin-inline: 1.5rem;
  }

  .achievements h2 {
    color: var(--color-cloud);
  }

  .contact-cta {
    background: var(--color-accent-soft);
    border-radius: var(--radius-lg);
    margin-inline: 1.5rem;
  }

  .contact-cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .contact-cta__inner h2 {
    margin-bottom: 0.4rem;
  }

  .contact-cta__inner p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .achievements,
    .contact-cta {
      margin-inline: 0;
      border-radius: 0;
    }
  }
</style>
