---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServicePageBody from '../../components/ServicePageBody.astro';
import { getSite } from '../../content/site';

const locale = 'es' as const;
const { pm } = getSite(locale);
---

<BaseLayout
  locale={locale}
  title={pm.meta.title}
  description={pm.meta.description}
  path="/es/project-manager"
  altPath="/project-manager"
>
  <ServicePageBody content={pm} contactHref="/es/contact" />
</BaseLayout>
